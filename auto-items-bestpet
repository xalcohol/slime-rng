-- LocalScript: instant loot teleport + auto-equip best every 3 minutes
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")

local lootFolder = workspace:WaitForChild("Loot")

-- Remote reference
local inventoryRemote = ReplicatedStorage
    :WaitForChild("Packages")
    :WaitForChild("_Index")
    :WaitForChild("leifstout_networker@0.3.1")
    :WaitForChild("networker")
    :WaitForChild("_remotes")
    :WaitForChild("InventoryService")
    :WaitForChild("RemoteFunction")

-- Auto-equip
local function equipBest()
    inventoryRemote:InvokeServer("requestEquipBest")
end

equipBest()
task.spawn(function()
    while true do
        task.wait(180)
        equipBest()
    end
end)

-- Instantly teleport a single loot item to the player
local function grabItem(item)
    if not item:IsA("Model") then return end
    if item.PrimaryPart then
        item:SetPrimaryPartCFrame(hrp.CFrame + Vector3.new(0, 3, 0))
    end
end

-- Handle loot already on the ground when script starts
for _, item in ipairs(lootFolder:GetChildren()) do
    grabItem(item)
end

-- Handle new loot as it spawns
lootFolder.ChildAdded:Connect(grabItem)
